  326          static uint8 dl1a_perform_single_ref_calibration (uint8 vhv_init_byte)
  327          {
  328   1          uint8 return_state = 0;
  329   1          uint8 data_buffer = 0;
  330   1          volatile uint16 loop_count = 0;
  331   1          
  332   1          do
  333   1          {
  334   2              dl1a_write_register(DL1A_SYSRANGE_START, 0x01 | vhv_init_byte);
  335   2              dl1a_read_registers(DL1A_MSRC_CONFIG_TIMEOUT_MACROP, &data_buffer, 1);
  336   2              
  337   2              while(0 == (data_buffer & 0x07))
  338   2              {
  339   3                  system_delay_ms(1);
  340   3                  dl1a_read_registers(DL1A_MSRC_CONFIG_TIMEOUT_MACROP, &data_buffer, 1);
  341   3                  
  342   3                  if(DL1A_TIMEOUT_COUNT < loop_count ++)
  343   3                  {
  344   4                      return_state = 1;
  345   4                      break;
  346   4                  }
  347   3              }
C251 COMPILER V5.60.0,  zf_device_dl1a                                                     07/05/26  21:05:11  PAGE 7   

  348   2              
  349   2              if(return_state)
  350   2              {
  351   3                  break;
  352   3              }
  353   2              
  354   2              dl1a_write_register(DL1A_SYSTEM_INTERRUPT_CLEAR, 0x01);
  355   2              dl1a_write_register(DL1A_SYSRANGE_START, 0x00);
  356   2          }
  357   1          while(0);
  358   1          
  359   1          return return_state;
  360   1      }
