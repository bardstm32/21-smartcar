  347   4                  }
  348   3              }
  349   2              
  350   2              if(return_state)
  351   2              {
  352   3                  break;
  353   3              }
  354   2              
  355   2              dl1a_write_register(DL1A_SYSTEM_INTERRUPT_CLEAR, 0x01);
  356   2              dl1a_write_register(DL1A_SYSRANGE_START, 0x00);
  357   2          }
  358   1          while(0);
  359   1          
  360   1          return return_state;
  361   1      }
