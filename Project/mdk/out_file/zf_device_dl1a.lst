  196          static uint16 dl1a_decode_timeout (uint16 reg_val)
  197          {
  198   1          // ж јејҸ: (LSByte * 2 ^ MSByte) + 1
  199   1          return  (uint16)((reg_val & 0x00FF) <<
  200   1                           (uint16)((reg_val & 0xFF00) >> 8)) + 1;
  201   1      }
  202          
  203          //-------------------------------------------------------------------------------------------------------
             -------------
  204          // еҮҪж•°з®Җд»Ӣ     еҜ№и¶…ж—¶ж•°еҖјиҝӣиЎҢзј–з Ғ
  205          // еҸӮж•°иҜҙжҳҺ     timeout_mclks   и¶…ж—¶ж—¶й•ҝ -MCLKs еҖј
  206          // иҝ”еӣһеҸӮж•°     uint16          иҝ”еӣһзј–з ҒеҖј
  207          // дҪҝз”ЁзӨәдҫӢ     dl1a_encode_timeout(timeout_mclks);
  208          // еӨҮжіЁдҝЎжҒҜ     еңЁ MCLK дёӯеҜ№и¶…ж—¶зҡ„еәҸеҲ—жӯҘйӘӨи¶…ж—¶еҜ„еӯҳеҷЁеҖјиҝӣиЎҢзј–з Ғ
  209          //-------------------------------------------------------------------------------------------------------
             -------------
  210          static uint16 dl1a_encode_timeout (uint16 timeout_mclks)
  211          {
  212   1          uint32 edata ls_byte = 0;
  213   1          uint16 edata ms_byte = 0;
  214   1          uint16 edata return_data = 0;
  215   1          
  216   1          if (timeout_mclks > 0)
  217   1          {
  218   2              // ж јејҸ: (LSByte * 2 ^ MSByte) + 1
  219   2              ls_byte = timeout_mclks - 1;
  220   2              
  221   2              while ((ls_byte & 0xFFFFFF00) > 0)
  222   2              {
  223   3                  ls_byte >>= 1;
  224   3                  ms_byte++;
  225   3              }
  226   2              
  227   2              return_data = (ms_byte << 8) | (ls_byte & 0xFF);
  228   2          }
