  197          //  @brief      扩展EEPROM写多个字节(无需擦除)
  198          //  @param      addr                    需要写的eeprom地址
  199          //  @param      *buf                    需要写的数据地址
  200          //  @param      len                             需要写的数据长度
  201          //  @return     void
  202          //  Sample usage:                       extern_iap_write_bytes(0x0000,(uint8 *)"0123456789",10);
  203          //                                                              将"0123456789"写入0x00-0x0A地址中;
  204          //      @note：                                         不要跨扇区使用。
  205          //                                                              addr地址：0-511为一个扇区,512-1023为一个扇区，1024-1535为一个扇区，依次类推。
  206          //-------------------------------------------------------------------------------------------------------
             -------------
  207          void extern_iap_write_buff(uint16 addr, uint8 *buf, uint16 len)
  208          {
  209   1          uint8 temp[512] = {0};
  210   1          uint16 i;
  211   1          
  212   1          for(i = 0; i < 512 ; i++)   temp[i] = 0;                                            //清0
  213   1          
  214   1          iap_read_buff(addr & 0xFE00, temp, 512);                                            //读取
  215   1          
  216   1          for(i = 0; i < len; i++)    temp[(addr & 0x1FF) + i] = buf[i];      //改
  217   1          
  218   1          iap_erase_page(addr);                                                                                       //擦除
  219   1          iap_write_buff(addr & 0xFE00, temp, 512);                                   //写入
  220   1      }
