  131          //  @brief      EEPROM读取多个字节
  132          //  @param      addr                    需要读取的eeprom地址
  133          //  @param      *buf                    需要读取的数据地址
  134          //  @param      len                             需要读取的数据长度
  135          //  @return     void
  136          //  Sample usage:               uint8 str[10];
  137          //                                                              iap_read_bytes(0x00,str,10);
  138          //                                                              将0x00-0x0A地址中的数据，读取到str中。
  139          //-------------------------------------------------------------------------------------------------------
             -------------
  140          void iap_read_buff(uint32 addr, uint8 *buf, uint16 len)
  141          {
  142   1          while(len--)
  143   1          {
  144   2              *buf++ = iap_read_byte(addr);           //读 IAP 数据
  145   2              addr++;
  146   2          }
  147   1      }
