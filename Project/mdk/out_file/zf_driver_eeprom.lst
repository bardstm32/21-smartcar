   18   1          _nop_();   //由于STC32G是多级流水线的指令系统，触发命令后建议加4个NOP，保证IAP_DATA的数据完成准备
   19   1          _nop_();
   20   1          _nop_();
   21   1          _nop_();
   22   1      
   23   1      }
