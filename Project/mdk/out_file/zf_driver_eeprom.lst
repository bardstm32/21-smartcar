  172          //  @brief      EEPROM擦除目标地址所在的一页（1扇区/512字节）
  173          //  @param      addr                    需要写的eeprom地址
  174          //  @return     void
  175          //  Sample usage:                       iap_erase_page(0x20);
  176          //                                                              擦除0x00-0x200的数据
  177          //-------------------------------------------------------------------------------------------------------
             -------------
  178          void iap_erase_page(uint32 addr)
  179          {
  180   1              bit flag = 0;
  181   1      
  182   1              flag = EA;
  183   1              EA = 0;
  184   1          IAP_CMD = 3;                                //设置 IAP 擦除命令
  185   1          IAP_ADDRL = addr;                   //设置 IAP 低地址
  186   1          IAP_ADDRH = addr >> 8;      //设置 IAP 高地址
  187   1          IAP_ADDRE = addr >> 16;             //设置 IAP 最高地址
  188   1          eeprom_trig();
  189   1          
  190   1              EA = flag;
  191   1          system_delay_ms(10);                //擦除1扇区(512字节)：约4-6ms
  192   1      }
