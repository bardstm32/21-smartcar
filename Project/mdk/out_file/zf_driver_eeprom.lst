  157          //                                                              将"0123456789"写入0x00-0x0A地址中;
  158          //-------------------------------------------------------------------------------------------------------
             -------------
  159          void iap_write_buff(uint32 addr, uint8 *buf, uint16 len)
  160          {
  161   1              while(len--)
  162   1          {
  163   2              iap_write_byte(addr, *buf);             //读 IAP 数据
  164   2              addr++;
  165   2                      buf++;
  166   2          }
  167   1      }
