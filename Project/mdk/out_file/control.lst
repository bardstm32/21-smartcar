   74   2              pid->integral += pid->error;
   75   2              if (pid->integral > pid->max_integral)
   76   2                  pid->integral = pid->max_integral;
   77   2              if (pid->integral < -pid->max_integral)
   78   2                  pid->integral = -pid->max_integral;
   79   2          }
   80   1          else
   81   1          {
   82   2              pid->integral = 0;
   83   2          }
   84   1      
   85   1          // 位置式PID公式：U = Kp*E[k] + Ki*ΣE + Kd*(E[k]-E[k-1])
   86   1          pid->output = pid->kp * pid->error +
   87   1                        pid->ki * pid->integral +
   88   1                        pid->kd * (pid->error - pid->last_error);
   89   1      
   90   1          pid->last_error = pid->error;
   91   1      
   92   1          return pid->output;
   93   1      }
