   40          /**
   41           * @brief 增量式 PID 计算 (专用于内环速度环)
   42           * 输出的是控制量的增量，累加后作为最终占空比
   43           */
   44          float PID_Inc_Calc(PID_TypeDef *pid, float target, float current)
   45          {
   46   1              float p_out,i_out,d_out;
   47   1          pid->error = target - current;
   48   1      
   49   1          // 增量式PID公式：ΔU = Kp*(E[k]-E[k-1]) + Ki*E[k] + Kd*(E[k]-2*E[k-1]+E[k-2])
   50   1          p_out = pid->kp * (pid->error - pid->last_error);
   51   1          i_out = pid->ki * pid->error;
   52   1          d_out = pid->kd * (pid->error - 2 * pid->last_error + pid->prev_error);
   53   1      
   54   1          pid->output += (p_out + i_out + d_out);
   55   1      
   56   1          // 更新历史误差
