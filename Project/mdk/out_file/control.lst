   33   1          uint16 R_V = ind_data[3]; // 右竖
   34   1          uint16 R_H = ind_data[4]; // 右横
   35   1      
   36   1          // 丢线检测
   37   1          if ((L_V + R_V + L_H + R_H) < LOST_LINE_SUM)
   38   1          {
