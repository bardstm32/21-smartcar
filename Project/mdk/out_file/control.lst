   72          /**
   73           * @brief 优化后的差比和误差计算
   74           * @param ind_data 经过滤波后的四电感数组
   75           * @return float 计算出的最终偏差值
   76           */
   77          float Track_Get_Optimized_Error(uint16 *ind_data)
   78          {
   79   1          float scaled_err = 0.0f;
   80   1              float denominator,numerator;
   81   1          uint16 L_H = ind_data[1];
   82   1          uint16 L_V = ind_data[2];
   83   1          uint16 R_V = ind_data[3];
   84   1          uint16 R_H = ind_data[4];
   85   1      
   86   1          // 分母防零除保护
   87   1          denominator = Str_value * (float)(L_H + R_H) + Cur_value * (float)(L_V + R_V);
   88   1          if (denominator < 1.0f)
   89   1          {
   90   2              return track_pid.last_error; // 如果分母过小，维持上次偏差
   91   2          }
   92   1      
   93   1          // 基础差比和计算 (引入了你原代码中的 Str_value 和 Cur_value 权重)
   94   1          numerator = Str_value * (float)((int32)L_H - R_H) + Cur_value * (float)((int32)L_V - R_V);
   95   1          scaled_err = (numerator / denominator) * 100.0f;
   96   1      
   97   1          // 限幅保护
   98   1          scaled_err = range_protect(scaled_err, -100.0, 100.0);
   99   1      
  100   1          // --- 根据赛道元素强行修正偏差 ---
  101   1          switch (current_track_state)
  102   1          {
  103   2          case TRACK_CROSS:
  104   2              // 十字路口中心通常会丢线或严重畸变，直接锁死偏差为0，让车直冲过去
  105   2              scaled_err = 0.0f;
  106   2              break;
  107   2          case TRACK_RING_L_IN:
  108   2              // 检测到左环岛，强行赋予一个极大的负偏差，让车猛烈向左打角进环
  109   2              scaled_err = -80.0f;
  110   2              break;
  111   2          case TRACK_RING_R_IN:
  112   2              // 检测到右环岛，强行向右切入
  113   2              scaled_err = 80.0f;
  114   2              break;
  115   2          default:
  116   2              break;
  117   2          }
  118   1      
  119   1          return scaled_err;
  120   1      }
