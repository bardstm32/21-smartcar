  123           * @brief 核心控制执行函数 (建议在定时器中断中调用，如 5ms 一次)
  124           * 包含：采数据 -> 判元素 -> 算PID -> 差速输出
  125           */
  126          void Track_Execute_Steering(void)
  127          {
  128   1          uint16 ind_filtered[5] = {0};
  129   1          int16 speed_L = 0, speed_R = 0;
  130   1      
  131   1          // 1. 读取并滤波电感数据 (调用你 inductance.c 中的函数)
  132   1          Inductance_Read(ind_filtered);
  133   1      
  134   1          // 2. 赛道元素识别更新
  135   1          Track_Element_Recognize(ind_filtered);
  136   1      
  137   1          // 3. 丢线停车保护
  138   1          if (current_track_state == TRACK_LOST)
  139   1          {
  140   2              motor_L(0);
  141   2              motor_R(0);
  142   2              return;
  143   2          }
  144   1      
  145   1          // 4. 获取计算出的偏差
  146   1          track_pid.error = Track_Get_Optimized_Error(ind_filtered);
  147   1      
  148   1          // 5. PD 位置式计算
  149   1          track_pid.output = track_pid.kp * track_pid.error +
  150   1                             track_pid.kd * (track_pid.error - track_pid.last_error);
  151   1          track_pid.last_error = track_pid.error;
  152   1      
  153   1          // 6. 差速计算 (基础速度 ± 转向PWM)
  154   1          // 假设 error 为正时车体偏右，需要向左拐 -> 左轮减速，右轮加速
  155   1          speed_L = BASE_SPEED - (int16)track_pid.output;
  156   1          speed_R = BASE_SPEED + (int16)track_pid.output;
  157   1      
  158   1          // 7. 速度限幅 (匹配你 motor.c 中 -100 到 100 的范围)
  159   1          speed_L = (int16)range_protect(speed_L, MIN_SPEED, MAX_SPEED);
  160   1          speed_R = (int16)range_protect(speed_R, MIN_SPEED, MAX_SPEED);
  161   1      
  162   1          // 8. 驱动底层电机
  163   1          motor_L(speed_L);
  164   1          motor_R(speed_R);
