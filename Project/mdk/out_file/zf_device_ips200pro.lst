  242          uint8 ips200pro_receive_buffer(void *buffer, uint32 length, uint32 time_out)
  243          {
  244   1          uint8 return_state = 1;
  245   1      
  246   1          if(     ((0 == time_out) || (0 == ips200pro_wait_idle(time_out)))   // зӯүеҫ…жңӘи¶…ж—¶
  247   1              &&  (IPS200PRO_SPI_LENGTH >= length)                            // ж•°жҚ®йҮҸжңӘи¶…иҝҮйҷҗеҲ¶
  248   1              &&  (NULL != buffer))                                           // жҢҮй’ҲдёҚдёәз©ә
  249   1          {
  250   2              IPS200PRO_CS(0);
