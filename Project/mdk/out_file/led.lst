    1          /********************************************************************************************************
             -*************
    2           *  @file  Buzzer.c
    3           *  @brief  LED初始化与控制
    4           * 该文件包含了LED初始化、打开和关闭的相关函数。
    5           * 通过初始化指定的GPIO引脚来控制LED的开关状态。
    6           * 根据需要，可以在头文件中修改LED的引脚配置。
    7           *  @date              @author            备注
    8           *  2025-12-21        三帅勇闯智能车-rw   初始版本
    9           *  修改记录：
   10           *  @date              @author            备注
   11           *
   12           ********************************************************************************************************
             -************/
   13          
   14          #include "zf_common_headfile.h"
   15          #include "LED.h"
   16          
   17          /**
   18           * @brief 初始化LED,可根据头文件修改引脚
   19           * @param 无
   20           * @return 无
   21           */
   22          void LED_Init(void)
   23          {
   24   1          gpio_init(LED1, GPO, 1, GPO_PUSH_PULL);
   25   1          gpio_init(LED2, GPO, 1, GPO_PUSH_PULL);
   26   1              LED_Off(LED1);
   27   1      }
   28          
   29          /**
   30           * @brief 点亮LED
   31           * @param pin：LED引脚
   32           * @return 无
   33           */
   34          void LED_On(gpio_pin_enum pin)
   35          {
   36   1          gpio_set_level(pin, 0);
   37   1      }
   38          
   39          /**
   40           * @brief 熄灭LED
   41           * @param pin：LED引脚
   42           * @return 无
   43           */
   44          void LED_Off(gpio_pin_enum pin)
   45          {
   46   1          gpio_set_level(pin, 1);
   47   1      }
   48          
   49          void LED_Switch(gpio_pin_enum pin)
   50          {
   51   1          gpio_set_level(pin, !(gpio_get_level(pin)));
   52   1      }


