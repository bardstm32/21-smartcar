   12           ********************************************************************************************************
             -************/
   13          #include "zf_common_headfile.h"
   14          /**
   15           * @brief 初始化LED,可根据头文件修改引脚
   16           * @param 无
   17           * @return 无
   18           */
   19          void LED_Init(void)
   20          {
   21   1          gpio_init(LED1, GPO, 1, GPO_PUSH_PULL);
   22   1          gpio_init(LED2, GPO, 1, GPO_PUSH_PULL);
   23   1      }
   24          
   25          /**
   26           * @brief 点亮LED
   27           * @param pin：LED引脚
   28           * @return 无
   29           */
   30          void LED_On(gpio_pin_enum pin)
   31          {
   32   1          gpio_set_level(pin, 0);
   33   1      }
   34          
   35          /**
   36           * @brief 熄灭LED
   37           * @param pin：LED引脚
   38           * @return 无
   39           */
   40          void LED_Off(gpio_pin_enum pin)
   41          {
   42   1          gpio_set_level(pin, 1);
   43   1      }
   44          
   45          void LED_Switch(gpio_pin_enum pin)
   46          {
   47   1          gpio_set_level(pin, !(gpio_get_level(pin)));
   48   1      }


