    1          /********************************************************************************************************
             -*************
    2           *  @file  Buzzer.c
    3           *  @brief  LED初始化与控制
    4           * 该文件包含了LED初始化、打开和关闭的相关函数。
    5           * 通过初始化指定的GPIO引脚来控制LED的开关状态。
    6           * 根据需要，可以在头文件中修改LED的引脚配置。
    7           *  @date              @author            备注
    8           *  2025-12-21        三帅勇闯智能车-rw   初始版本
    9           *  修改记录：
   10           *  @date              @author            备注
   11           *
   12           ********************************************************************************************************
             -************/
   13          
   14          #include "zf_common_headfile.h"
   15          #include "LED.h"
   16          
   17          /**
   18           * @brief 初始化LED,可根据头文件修改引脚
   19           * @param 无
   20           * @return 无
   21           */
   22          void LED_Init(void)
   23          {
   24   1          gpio_init(LED1, GPO, 1, GPO_PUSH_PULL);
   25   1          gpio_init(LED2, GPO, 1, GPO_PUSH_PULL);
   26   1      }
   27          
   28          /**
   29           * @brief 点亮LED
   30           * @param pin：LED引脚
   31           * @return 无
   32           */
   33          void LED_On(gpio_pin_enum pin)
   34          {
   35   1          gpio_set_level(pin, 0);
   36   1      }
   37          
   38          /**
   39           * @brief 熄灭LED
   40           * @param pin：LED引脚
   41           * @return 无
   42           */
   43          void LED_Off(gpio_pin_enum pin)
   44          {
   45   1          gpio_set_level(pin, 1);
   46   1      }
   47          
   48          void LED_Switch(gpio_pin_enum pin)
   49          {
   50   1          gpio_set_level(pin, !(gpio_get_level(pin)));
   51   1      }


