  223          float fast_sqrt(float num)
  224          {
  225   1          float halfx = 0.5f * num;
  226   1          float y = num;
  227   1          long i = *(long *)&y;
  228   1          i = 0x5f375a86 - (i >> 1);
  229   1      
  230   1          y = *(float *)&i;
  231   1          y = y * (1.5f - (halfx * y * y));
  232   1          y = y * (1.5f - (halfx * y * y));
  233   1          return y;
  234   1      }
