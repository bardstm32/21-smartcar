  219          float fast_sqrt(float num)
  220          {
  221   1          float halfx = 0.5f * num;
  222   1          float y = num;
  223   1          long i = *(long *)&y;
  224   1          i = 0x5f375a86 - (i >> 1);
  225   1      
  226   1          y = *(float *)&i;
  227   1          y = y * (1.5f - (halfx * y * y));
  228   1          y = y * (1.5f - (halfx * y * y));
  229   1          return y;
  230   1      }
