  262   1          p->X_now = p->X_mid + p->kg * (dat - p->X_mid);
  263   1          p->P_now = (1 - p->kg) * p->P_mid;
  264   1          p->P_last = p->P_now;
  265   1          p->X_last = p->X_now;
  266   1          return p->X_now;
  267   1      }
