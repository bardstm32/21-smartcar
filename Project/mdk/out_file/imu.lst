  227          float fast_sqrt(float num)
  228          {
  229   1          float halfx = 0.5f * num;
  230   1          float y = num;
  231   1          long i = *(long *)&y;
  232   1          i = 0x5f375a86 - (i >> 1);
  233   1      
  234   1          y = *(float *)&i;
  235   1          y = y * (1.5f - (halfx * y * y));
  236   1          y = y * (1.5f - (halfx * y * y));
  237   1          return y;
  238   1      }
