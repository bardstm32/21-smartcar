  231          float fast_sqrt(float num)
  232          {
  233   1          float halfx = 0.5f * num;
  234   1          float y = num;
  235   1          long i = *(long *)&y;
  236   1          i = 0x5f375a86 - (i >> 1);
  237   1      
  238   1          y = *(float *)&i;
  239   1          y = y * (1.5f - (halfx * y * y));
  240   1          y = y * (1.5f - (halfx * y * y));
  241   1          return y;
  242   1      }
