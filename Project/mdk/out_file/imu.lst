  254          float KalmanFilter(extKalman_t *p, float dat)
  255          {
  256   1          p->X_mid = p->A * p->X_last;
  257   1          p->P_mid = p->A * p->P_last + p->Q;
  258   1          p->kg = p->P_mid / (p->P_mid + p->R);
  259   1          p->X_now = p->X_mid + p->kg * (dat - p->X_mid);
  260   1          p->P_now = (1 - p->kg) * p->P_mid;
  261   1          p->P_last = p->P_now;
  262   1          p->X_last = p->X_now;
  263   1          return p->X_now;
  264   1      }
