   85   1          // 1. МЦЫуЕБЧАЮѓВю
   86   1          pid->err = pid->target - speed_f;
   87   1      
   88   1          // 2. МЦЫуЪфГідіСП (ІЄU)
   89   1          inc_out = (pid->Kp * (pid->err - pid->last_err) +pid->Ki * pid->err);
   90   1              if(inc_out > MAX_INC)  inc_out = MAX_INC;
