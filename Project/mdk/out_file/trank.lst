   56          float PID_Calc(PID_TypeDef *pid, float target, float measure)
   57          {
   58   1          pid->target = target;
   59   1          pid->measure = measure;
   60   1          
   61   1          // јЖЛгОуІо
   62   1          pid->err = pid->target - pid->measure;
   63   1          
   64   1          // ұИАэПо
   65   1          pid->P = pid->Kp * pid->err;  
   66   1          // Оў·ЦПо
   67   1          pid->D = pid->Kd * (pid->err - pid->last_err);  
   68   1          // ЧЬКдіц+ПЮ·щ
   69   1          pid->out = pid->P + pid->D;
   70   1          if(pid->out >  pid->max_out)  pid->out =  pid->max_out;
   71   1          if(pid->out < -pid->max_out)  pid->out = -pid->max_out;
   72   1          
   73   1          // ёьРВОуІо
   74   1          pid->last_err = pid->err;
   75   1          
   76   1          return pid->out;
   77   1      }
