   94   1          // 4. ЪфГіЯоЗљ (ЗРжЙPWMХмЗЩ)
   95   1          if (pid->out > pid->max_out)
   96   1              pid->out = pid->max_out;
   97   1          if (pid->out < -pid->max_out)
