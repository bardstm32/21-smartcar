   58          float PID_Calc(PID_TypeDef *pid, float target, float measure)
   59          {
   60   1          pid->target = target;
   61   1          pid->measure = measure;
   62   1          
   63   1          // МЦЫуЮѓВю
   64   1          pid->err = pid->target - pid->measure;
   65   1          
   66   1          // БШР§Яю
   67   1          pid->P = pid->Kp * pid->err;  
   68   1              pid->P2 = pid->Kp2 * pid->err*My_abs(pid->err);  
   69   1      
   70   1          // ЮЂЗжЯю
   71   1          pid->D = pid->Kd * (pid->err - pid->last_err);  
   72   1          // змЪфГі+ЯоЗљ
   73   1              pid->last_f_speed=pid->err - pid->last_err;
   74   1              
   75   1          pid->out = pid->P + pid->P2+ pid->D;   
   76   1          // ИќаТЮѓВю
   77   1          pid->last_err = pid->err;
   78   1          
   79   1          return pid->out;
   80   1      }
