  127          /* діСПЪНЫйЖШ PIDЃЈДјЬѕМўЛ§Зж anti-windupЃЉ                                 */
  128          /*   ЦеЭЈдіСПЪНЃКdU = Kp*(e - e_prev) + Ki*eЃЌУПжмЦкРлМгЕН out               */
  129          /*   ЮЪЬтЃКout ЖЄдкБЅКЭжЕЪБШєЮѓВюШдЭЌЯђЃЌKi ГжајРлМгЃЛзшСІЯћЪЇКѓЮоЗЈСЂПЬЭЫБЅКЭ */
  130          /*   зіЗЈЃКЕБ out вбБЅКЭЧвЮѓВюШддкЭЦЫќМЬајБЅКЭЗНЯђЪБЃЌБОжмЦкАбЛ§ЗжЯюжУ 0        */
  131          void IncPID_Calc(PID_TypeDef *pid, int16 current_speed)
  132          {
  133   1          pid->err = pid->target - current_speed;                                /* БОжмЦкЫйЖШЮѓВю e(k) = targe
             -t - ЪЕМЪ */                                                                  /* Зёдђе§ГЃМЦЫуЛ§ЗждіСП */
  134   1          pid->I = pid->Ki * pid->err;                                       /*   ЕЅВНЛ§ЗжЯю = Ki * e(k) */
  135   1              pid->P=pid->Kp * (pid->err - pid->last_err) ;
  136   1          pid->inc_out = pid->P + pid->I;          /* ЕЅВНдіСП dU = Kp*de + Ki*e */
  137   1          pid->out += pid->inc_out;                                              /* РлМгЕНЕБЧАЪфГі */
  138   1      
  139   1          if (pid->out >  pid->max_out) pid->out =  pid->max_out;                /* е§ЯђгВЯоЗљЃЈЗР PWM вчГіЃЉ *
             -/
  140   1          if (pid->out < -pid->max_out) pid->out = -pid->max_out;                /* ЗДЯђгВЯоЗљ */
  141   1      
  142   1          pid->last_err = pid->err;                                              /* БЃДцБОДЮЮѓВюЃЌЙЉЯТДЮВюЗжЪЙг
             -У */
  143   1      }
