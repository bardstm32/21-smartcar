   83   1      
   84   1          // 2. МЦЫуЪфГідіСП (ІЄU)
   85   1          inc_out = (int16)(pid->Kp * (pid->err - pid->last_err) +
   86   1                                  pid->Ki * pid->err +
   87   1                                  pid->Kd * (pid->err - 2 * pid->last_err + pid->prev_err));
   88   1      
   89   1          // 3. РлМгдіСПЕУЕНзюжеЪЕМЪЪфГі
   90   1          pid->out += inc_out;
   91   1      
   92   1          // 4. ЪфГіЯоЗљ (ЗРжЙPWMХмЗЩ)
   93   1          if (pid->out > pid->max_out)
   94   1              pid->out = pid->max_out;
   95   1          if (pid->out < -pid->max_out)
   96   1              pid->out = -pid->max_out;
   97   1          // 5. БЃДцРњЪЗЮѓВюЃЌЙЉЯТвЛДЮМЦЫуЪЙгУ
   98   1          pid->prev_err = pid->last_err;
   99   1          pid->last_err = pid->err;
  100   1      }
