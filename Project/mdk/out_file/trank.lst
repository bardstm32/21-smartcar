   57          float PID_Calc(PID_TypeDef *pid, float target, float measure)
   58          {
   59   1          pid->target = target;
   60   1          pid->measure = measure;
   61   1          
   62   1          // МЦЫуЮѓВю
   63   1          pid->err = pid->target - pid->measure;
   64   1          
   65   1          // БШР§Яю
   66   1          pid->P = pid->Kp * pid->err;  
   67   1          // ЮЂЗжЯю
   68   1          pid->D = pid->Kd * (pid->err - pid->last_err);  
   69   1          // змЪфГі+ЯоЗљ
   70   1          pid->out = pid->P + pid->D;
   71   1          if(pid->out >  pid->max_out)  pid->out =  pid->max_out;
   72   1          if(pid->out < -pid->max_out)  pid->out = -pid->max_out;
   73   1          
   74   1          // ИќаТЮѓВю
   75   1          pid->last_err = pid->err;
   76   1          
   77   1          return pid->out;
   78   1      }
