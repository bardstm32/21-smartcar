   45           */
   46          float PID_Calc(PID_TypeDef *pid, float target, float measure)
   47          {
   48   1          pid->target = target;
   49   1          pid->measure = measure;
   50   1          
   51   1          // МЦЫуЮѓВю
   52   1          pid->err = pid->target - pid->measure;
   53   1          
   54   1          // БШР§Яю
   55   1          pid->P = pid->Kp * pid->err;
C251 COMPILER V5.60.0,  trank                                                              01/04/26  16:17:47  PAGE 2   

   56   1          
   57   1          // Л§ЗжЯю+ЯоЗљ
   58   1          pid->I += pid->Ki * pid->err;
   59   1          if(pid->I >  pid->max_i)  pid->I =  pid->max_i;
   60   1          if(pid->I < -pid->max_i)  pid->I = -pid->max_i;
   61   1          
   62   1          // ЮЂЗжЯю
   63   1          pid->D = pid->Kd * (pid->err - pid->last_err);
   64   1          
   65   1          // змЪфГі+ЯоЗљ
   66   1          pid->out = pid->P + pid->I + pid->D;
   67   1          if(pid->out >  pid->max_out)  pid->out =  pid->max_out;
   68   1          if(pid->out < -pid->max_out)  pid->out = -pid->max_out;
   69   1          
   70   1          // ИќаТЮѓВю
   71   1          pid->last_err = pid->err;
   72   1          
   73   1          return pid->out;
   74   1      }
