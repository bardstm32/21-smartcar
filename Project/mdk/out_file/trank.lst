   46          float PID_Calc(PID_TypeDef *pid, float target, float measure)
   47          {
   48   1          pid->target = target;
   49   1          pid->measure = measure;
   50   1          
   51   1          // МЦЫуЮѓВю
   52   1          pid->err = pid->target - pid->measure;
   53   1          
   54   1          // БШР§Яю
   55   1          pid->P = pid->Kp * pid->err;
