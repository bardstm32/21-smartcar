    1          /********************************************************************************************************
             -*************
    2           *  @file  init.c
    3           *  @brief  初始化各个模块
    4           * 初始化智能车系统
    5           * 该函数用于初始化智能车系统中的各个模块，包括系统时钟、调试接口、中断
             -、电感传感器、蜂鸣器、IMU传感器、陀螺仪和无线通讯模块。
    6           * 初始化完成后，启用全局中断。
    7           *  @date              @author            备注
    8           *  2026-3-23        三帅勇闯智能车-rw   初始版本
    9           *  修改记录：
   10           *  @date              @author            备注
   11           *
   12           ********************************************************************************************************
             -************/
   13          #include "init.h"
   14          
   15          void Car_Init(void)
   16          {
   17   1          
   18   1          // 内部函数初始化
   19   1          clock_init(SYSTEM_CLOCK_30M);       // 系统时钟初始化
   20   1          debug_init();                       // 调试接口初始化
   21   1          interrupt_global_disable();         // 全局中断禁用
   22   1          gyro_init();                        // 陀螺仪初始化
   23   1          Menu_Init();                        // 菜单初始化
   24   1          pit_ms_init(TIM0_PIT, 1);           // 定时器初始化
   25   1      
   26   1          // 外部模块初始化
   27   1          Inductance_Init();                  // 电感初始化
   28   1          Buzzer_Init();                      // 蜂鸣器初始化
   29   1          wireless_uart_init();               // 无线UART通讯初始化（调试用）
   30   1          imu660ra_init();                    // IMU660RA传感器初始化
   31   1      
   32   1          interrupt_global_enable();            // 全局中断使能
   33   1      }


