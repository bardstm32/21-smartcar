   78          //-------------------------------------------------------------------------------------------------------
             -------------
   79          void adc_init(adc_channel_enum ch, adc_resolution_enum resolution)
   80          {
   81   1          ADC_CONTR |= 1 << 7;                                //1 ЃКДђПЊ ADC ЕчдД
   82   1          
   83   1          ADC_CONTR &= (0xF0);                        //ЧхГ§ADC_CHS[3:0] ЃК ADC ФЃФтЭЈЕРбЁдёЮЛ
   84   1          ADC_CONTR |= ch;
   85   1          
   86   1          if((ch >> 3) == 1) //P0.0
   87   1          {
   88   2              //IOПкашвЊЩшжУЮЊИпзшЪфШы
   89   2              P0M0 &= ~(1 << (ch & 0x07));
   90   2              P0M1 |= (1 << (ch & 0x07));
   91   2          }
   92   1          else if((ch >> 3) == 0) //P1.0
   93   1          {
   94   2              //IOПкашвЊЩшжУЮЊИпзшЪфШы
   95   2              P1M0 &= ~(1 << (ch & 0x07));
   96   2              P1M1 |= (1 << (ch & 0x07));
   97   2          }
   98   1          
   99   1          ADCCFG |= ADC_SYSclk_DIV_16 & 0x0F;                 //ADCЪБжгЦЕТЪSYSclk/16&0x0F;
  100   1          
  101   1          ADCCFG |= 1 << 5;                                                   //зЊЛЛНсЙћгвЖдЦыЁЃ ADC_RES БЃДцНсЙћЕФИп 2 ЮЛЃЌ ADC_RESL БЃДцНсЙћЕФЕЭ 8 ЮЛЁЃ
  102   1              
  103   1              adc_resolution = resolution;           // МЧТМADCОЋЖШ НЋдкВЩМЏЪБЪЙгУ
  104   1      }
