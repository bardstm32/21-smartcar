   45          //-------------------------------------------------------------------------------------------------------
             -------------
   46          uint16 adc_convert(adc_channel_enum ch)
   47          {
   48   1          uint16 adc_value;
   49   1          
   50   1          ADC_CONTR &= (0xF0);                        //ЧхГ§ADC_CHS[3:0] ЃК ADC ФЃФтЭЈЕРбЁдёЮЛ
   51   1          ADC_CONTR |= ch;
   52   1          
C251 COMPILER V5.60.0,  zf_driver_adc                                                      17/05/26  17:30:59  PAGE 2   

   53   1          ADC_CONTR |= 0x40;                          // ЦєЖЏ AD зЊЛЛ
   54   1          
   55   1          while (!(ADC_CONTR & 0x20));        // ВщбЏ ADC ЭъГЩБъжО
   56   1          
   57   1          ADC_CONTR &= ~0x20;                         // ЧхЭъГЩБъжО
   58   1          
   59   1          adc_value = ADC_RES;                        //ДцДЂ ADC ЕФ 12 ЮЛНсЙћЕФИп 4 ЮЛ
   60   1          adc_value <<= 8;
   61   1          adc_value |= ADC_RESL;              //ДцДЂ ADC ЕФ 12 ЮЛНсЙћЕФЕЭ 8 ЮЛ
   62   1          
   63   1          ADC_RES = 0;
   64   1          ADC_RESL = 0;
   65   1          
   66   1          adc_value >>= adc_resolution;       //ШЁЖрЩйЮЛ
   67   1          
   68   1          
   69   1          return adc_value;
   70   1      }
