   17          uint16 adc_mean_filter_convert (adc_channel_enum ch, const uint8 count)
   18          {
   19   1          uint8 i;
   20   1          uint16 sum;
   21   1              uint16 min,max;
   22   1              min=adc_average[0];
   23   1              max=adc_average[0];
   24   1              zf_assert(count);//ЖЯбдДЮЪ§ВЛФмЮЊ0
   25   1              
   26   1          sum = 0;
   27   1          for(i=0; i<count; i++)
   28   1          {
   29   2              adc_average[i]= adc_convert(ch);
   30   2                      if(adc_average[i]<min)min=adc_average[i];
   31   2                      if(adc_average[i]>max)max=adc_average[i];
   32   2                      sum+=adc_average[i];
   33   2          }
   34   1      
   35   1          sum = (sum-min-max)/(count-2);
   36   1          return sum;
   37   1      }
