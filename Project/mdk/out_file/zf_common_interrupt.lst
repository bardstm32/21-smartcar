    1          #include "zf_common_interrupt.h"
    2          
    3          //-------------------------------------------------------------------------------------------------------
             -------------
    4          // 函数简介     指定中断设置优先级
    5          // 参数说明     irqn            指定中断号 可查看 zf_common_interrupt.h 对应中断服务函数的标注
    6          // 参数说明     priority        抢占式优先级 0到3，0为最低优先级，3为最高优先级
    7          // 返回参数     void
    8          // 使用示例     interrupt_set_priority( TIMER0_IRQn, 3);
    9          //                                              设置周期中断定时器0的优先级为3
   10          //                                              禁止调用ch32v30x_misc里面的函数
   11          // 备注信息                              其余不能设置的，中断优先级全部为最低优先级0
   12          //-------------------------------------------------------------------------------------------------------
             -------------
   13          void interrupt_set_priority (irqn_type_enum irqn, uint8 priority)
   14          {
   15   1              if((irqn >> 4) == 0)
   16   1              {
   17   2                      IP  |= (priority & 0x01) << (irqn & 0x0F);
   18   2                      IPH |= ((priority >> 1) & 0x01) << (irqn & 0x0F);
   19   2              }
   20   1              else if((irqn >> 4) == 1)
   21   1              {
   22   2                      IP2  |= (priority & 0x01) << (irqn & 0x0F);
   23   2                      IP2H |= ((priority >> 1) & 0x01) << (irqn & 0x0F);
   24   2              }
   25   1              else if((irqn >> 4) == 2)
   26   1              {
   27   2      //              IP3  |= (priority & 0x01) << (irqn & 0x0F);
   28   2      //              IP3H |= ((priority >> 1) & 0x01) << (irqn & 0x0F);
   29   2              }
   30   1      }
