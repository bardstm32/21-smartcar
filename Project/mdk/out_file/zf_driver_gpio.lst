  322          // 函数简介     GPIO状态获取
  323          // 参数说明     pin         选择的引脚 (可选择范围由 zf_driver_gpio.h 内gpio_pin_enum枚举值确定)
  324          // 返回参数     uint8       0：低电平 1：高电平
  325          // 使用示例     uint8 status = gpio_get_level(IO_P00);//获取P00引脚电平
  326          //-------------------------------------------------------------------------------------------------------
             -------------
  327          uint8 gpio_get_level(gpio_pin_enum pin)
  328          {
  329   1          uint8 pin_bit = pin & 0x0F;
  330   1          uint8 port_flag = pin & 0xF0;
  331   1          uint8 status = 0;
  332   1      
  333   1          // 根据端口标志读取对应Pn寄存器
  334   1          switch (port_flag)
  335   1          {
  336   2          case IO_P00:
  337   2              status = P0 & (1 << pin_bit);
  338   2              break;
  339   2          case IO_P10:
  340   2              status = P1 & (1 << pin_bit);
  341   2              break;
  342   2          case IO_P20:
  343   2              status = P2 & (1 << pin_bit);
  344   2              break;
  345   2          case IO_P30:
  346   2              status = P3 & (1 << pin_bit);
  347   2              break;
  348   2          case IO_P40:
  349   2              status = P4 & (1 << pin_bit);
  350   2              break;
  351   2          case IO_P50:
  352   2              status = P5 & (1 << pin_bit);
  353   2              break;
  354   2          case IO_P60:
  355   2              status = P6 & (1 << pin_bit);
  356   2              break;
  357   2          case IO_P70:
  358   2              status = P7 & (1 << pin_bit);
  359   2              break;
  360   2          default:
  361   2              break; // 无效引脚
  362   2          }
  363   1      
  364   1          return status ? 1 : 0; // 转换为0/1返回
  365   1      }
