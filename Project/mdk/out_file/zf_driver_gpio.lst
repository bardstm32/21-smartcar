  367          //-------------------------------------------------------------------------------------------------------
             -------------
  368          // 函数简介     GPIO输出设置
  369          // 参数说明     pin         引脚号选择的引脚 (可选择范围由 common.h 内GPIO_PIN_enum枚举值确定)
  370          // 参数说明     dat         引脚的电平状态，输出时有效 0：低电平 1：高电平
  371          // 返回参数     void
  372          // 使用示例     gpio_set_level(D0, 0);//D0输出低电平
  373          //-------------------------------------------------------------------------------------------------------
             -------------
  374          void gpio_set_level(gpio_pin_enum pin, uint8 dat)
  375          {
  376   1          uint8 pin_bit = pin & 0x0F;
  377   1          uint8 port_flag = pin & 0xF0;
  378   1      
  379   1          // 三元运算符精简置位/清零逻辑
  380   1          switch (port_flag)
  381   1          {
C251 COMPILER V5.60.0,  zf_driver_gpio                                                     01/05/26  15:18:33  PAGE 7   

  382   2          case IO_P00:
  383   2              dat ? (P0 |= (1 << pin_bit)) : (P0 &= ~(1 << pin_bit));
  384   2              break;
  385   2          case IO_P10:
  386   2              dat ? (P1 |= (1 << pin_bit)) : (P1 &= ~(1 << pin_bit));
  387   2              break;
  388   2          case IO_P20:
  389   2              dat ? (P2 |= (1 << pin_bit)) : (P2 &= ~(1 << pin_bit));
  390   2              break;
  391   2          case IO_P30:
  392   2              dat ? (P3 |= (1 << pin_bit)) : (P3 &= ~(1 << pin_bit));
  393   2              break;
  394   2          case IO_P40:
  395   2              dat ? (P4 |= (1 << pin_bit)) : (P4 &= ~(1 << pin_bit));
  396   2              break;
  397   2          case IO_P50:
  398   2              dat ? (P5 |= (1 << pin_bit)) : (P5 &= ~(1 << pin_bit));
  399   2              break;
  400   2          case IO_P60:
  401   2              dat ? (P6 |= (1 << pin_bit)) : (P6 &= ~(1 << pin_bit));
  402   2              break;
  403   2          case IO_P70:
  404   2              dat ? (P7 |= (1 << pin_bit)) : (P7 &= ~(1 << pin_bit));
  405   2              break;
  406   2          default:
  407   2              break; // 无效引脚
  408   2          }
  409   1      }
