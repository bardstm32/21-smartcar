  447          void gpio_init(gpio_pin_enum pin, gpio_dir_enum dir, const uint8 dat, gpio_mode_enum mode)
  448          {
  449   1          zf_assert(dir == (mode >> 4));
  450   1      
  451   1          if (dir == GPIO)
  452   1          {
  453   2              gpio_set_dir(pin, GPIO);
  454   2              gpio_set_mode(pin, mode);
  455   2          }
  456   1          else if (dir == GPI)
  457   1          {
  458   2              if (mode == GPI_IMPEDANCE)
  459   2              {
  460   3                  gpio_set_impedance(pin);
  461   3              }
  462   2              else
  463   2              {
  464   3                  gpio_set_dir(pin, GPI);
  465   3                  gpio_set_mode(pin, mode);
  466   3              }
  467   2          }
  468   1          else if (dir == GPO)
  469   1          {
  470   2              if (GPO_PUSH_PULL == mode)
  471   2              {
  472   3                  gpio_set_dir(pin, GPO);
  473   3                  gpio_set_mode(pin, GPI_PULL_UP);
  474   3              }
  475   2              else if (GPO_OPEN_DTAIN == mode)
  476   2              {
  477   3                  gpio_set_mode(pin, GPO_OPEN_DTAIN);
  478   3              }
  479   2          }
  480   1          gpio_set_level(pin, dat);
  481   1      }


