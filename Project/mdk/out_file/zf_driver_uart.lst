  401   3                  //                T4L = brt;
  402   3                  //                T4H = brt >> 8;
  403   3                  //                T4T3M |= 0xa0;
  404   3                  //            }
  405   3                  
  406   3                  P_SW2 &= ~(0x01 << 2);
  407   3                  
  408   3                  if((UART4_RX_P02 == rx_pin) && (UART4_TX_P03 == tx_pin))
  409   3                  {
  410   4                      P_SW2 |= 0x00;
  411   4                  }
  412   3                  else if((UART4_RX_P52 == rx_pin) && (UART4_TX_P53 == tx_pin))
  413   3                  {
  414   4      //                P5M0 = 0x00;
  415   4      //                P5M1 = 0x01 << 2; //P5.2 需要设置为高阻
  416   4                      P_SW2 |= 0x04;
  417   4                  }
  418   3                  
  419   3                  //            IE2 |= 0x01 << 4;     //允许串行口4中断
  420   3                  
  421   3                  break;
  422   3              }
  423   2              
  424   2          }
  425   1          
  426   1              // uart dma 初始化
  427   1          uart_dma_init(uart_n);
  428   1          
  429   1      }


