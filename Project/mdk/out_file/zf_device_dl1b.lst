  104   4                      data_buffer[1] = DL1B_RESULT__FINAL_CROSSTALK_CORRECTED_RANGE_MM_SD0 & 0xFF;
  105   4                      dl1b_transfer_8bit_array(data_buffer, 2, data_buffer, 2);
