  106           */
  107          float Inductance_Count_Err(int16 L, int16 LM, int16 RM, int16 R)
  108          {
  109   1          float scaled_err;
  110   1              float numerator,denominator;
  111   1          numerator = ((L - R) + (LM - RM))*10000.0f;
  112   1          denominator = (L+R)+My_abs((LM-RM))+1;
  113   1      
  114   1          scaled_err = numerator / denominator;
  115   1          // 使用range_protect函数确保结果在[-10000.0, 10000.0]范围内
  116   1          scaled_err = range_protect_float(scaled_err, -10000, 10000);
  117   1          // 返回电感误差值
  118   1          return scaled_err;
  119   1      }
