   16          /**
   17           * range_protect - 将值限制在指定的最小值和最大值之间
   18           * 该函数接收一个值以及最小值和最大值作为参数，如果值大于最大值，则返回最大值；
   19           * 如果值小于最小值，则返回最小值；否则返回该值本身。
   20           * @param value     待限制的值
   21           * @param min_value 最小值
   22           * @param max_value 最大值
   23           * @return          限制在[min_value, max_value]之间的值
   24           */
   25          int16 range_protect_int(int16 value, int16 min_value, int16 max_value)
   26          {
   27   1          return (value > max_value) ? max_value : ((value < min_value) ? min_value : value);
   28   1      }
   29          
   30          float range_protect_float(float value, float min_value, float max_value)
   31          {
   32   1          return (value > max_value) ? max_value : ((value < min_value) ? min_value : value);
   33   1      }
