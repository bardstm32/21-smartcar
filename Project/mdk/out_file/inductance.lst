   76          /**
   77           * Adc_Normalize - 将ADC值归一化到指定范围
   78           * 该函数接收一个ADC值以及最大值和最小值作为参数，将ADC值归一化到0到100之间，
   79           * 并使用range_protect函数确保结果在[1.0, 100.0]范围内。
   80           * @param value     ADC值
   81           * @param max_value 最大值
   82           * @param min_value 最小值
   83           * @return          归一化后的值，范围在[1.0, 100.0]之间
   84           */
   85          double ADC_Normalize_0_100(uint16 adc_val, uint16 adc_max, uint16 adc_min)
   86          {
   87   1          double temp;
   88   1          // 公式：(值 - 最小值) * 100 / (最大值 - 最小值)
   89   1          temp = (adc_val* 100.0f)/ adc_max;
   90   1          // 限幅，防止越界
   91   1          if (temp > 100)
   92   1              temp = 100;
   93   1          if (temp < 0)
   94   1              temp = 0;
   95   1          return temp;
   96   1      }
