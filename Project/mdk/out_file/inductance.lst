   49          /**
   50           * Median_Average_Filter - 计算数组中去掉一个最大值和一个最小值后的平均值
   51           * 该函数接收一个整型数组和一个整数times作为参数，计算数组中去掉一个最大值
   52           * 和一个最小值后的平均值。适用于需要滤除异常值的场景。
   53           * @param arr   整型数组，包含待处理的数据
   54           * @param times 需要处理的数组元素个数
   55           * @return      去掉一个最大值和一个最小值后的数组元素平均值
C251 COMPILER V5.60.0,  inductance                                                         01/05/26  21:39:04  PAGE 2   

   56           */
   57          int Median_Average_Filter(int *arr, int times)
   58          {
   59   1          // 初始化最小值、最大值和累加和
   60   1          int min = arr[0], max = arr[0], sum = 0, i = 0;
   61   1      
   62   1          // 遍历数组，更新最小值、最大值，并计算累加和
   63   1          for (i = 0; i < times; i++)
   64   1          {
   65   2              if (arr[i] < min)
   66   2                  min = arr[i]; // 更新最小值
   67   2              if (arr[i] > max)
   68   2                  max = arr[i]; // 更新最大值
   69   2              sum += arr[i];    // 计算累加和
   70   2          }
   71   1      
   72   1          // 返回去掉最大值和最小值后的平均值
   73   1          // 注意：该方法假设times至少为3，否则会导致除以零的错误
   74   1          return (sum - min - max) / (times - 2);
   75   1      }
