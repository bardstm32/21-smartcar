   98          /* Inductance_Count_Err - 差比和计算（按公式修改版）
   99           * 该函数接收四个电感值作为参数，按公式计算电感误差并将其限制在-100到100之间。
  100           * @param L  电感值L（对应公式中a1）
  101           * @param LM 电感值LM（对应公式中a2）
  102           * @param RM 电感值RM（对应公式中b1）
  103           * @param R  电感值R（对应公式中b2）
  104           * @return   电感误差值，范围在[-100, 100]之间
  105           */
  106          float Inductance_Count_Err(int16 L, int16 LM, int16 RM, int16 R)
  107          {
  108   1          float scaled_err;
  109   1              float numerator,denominator;
  110   1          numerator = ((L - R) + (LM - RM))*10000.0f;
  111   1          denominator = L+R+LM+RM+1;
  112   1      
  113   1          scaled_err = numerator / denominator;
  114   1          // 使用range_protect函数确保结果在[-100.0, 100.0]范围内
  115   1          scaled_err = range_protect_int(scaled_err, -10000, 10000);
  116   1          // 返回电感误差值
  117   1          return scaled_err;
  118   1      }
