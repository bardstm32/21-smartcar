   42          /**
   43           * Median_Average_Filter - 计算数组中去掉一个最大值和一个最小值后的平均值
   44           * 该函数接收一个整型数组和一个整数times作为参数，计算数组中去掉一个最大值
   45           * 和一个最小值后的平均值。适用于需要滤除异常值的场景。
   46           * @param arr   整型数组，包含待处理的数据
   47           * @param times 需要处理的数组元素个数
   48           * @return      去掉一个最大值和一个最小值后的数组元素平均值
   49           */
   50          int Median_Average_Filter(int *arr, int times)
   51          {
   52   1          // 初始化最小值、最大值和累加和
   53   1          int min = arr[0], max = arr[0], sum = 0, i = 0;
   54   1      
   55   1          // 遍历数组，更新最小值、最大值，并计算累加和
C251 COMPILER V5.60.0,  inductance                                                         30/03/26  17:54:37  PAGE 2   

   56   1          for (i = 0; i < times; i++)
   57   1          {
   58   2              if (arr[i] < min)
   59   2                  min = arr[i]; // 更新最小值
   60   2              if (arr[i] > max)
   61   2                  max = arr[i]; // 更新最大值
   62   2              sum += arr[i];    // 计算累加和
   63   2          }
   64   1      
   65   1          // 返回去掉最大值和最小值后的平均值
   66   1          // 注意：该方法假设times至少为3，否则会导致除以零的错误
   67   1          return (sum - min - max) / (times - 2);
   68   1      }
