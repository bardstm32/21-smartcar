  100          int8 Inductance_Count_Err(uint16 L, uint16 LM, uint16 RM, uint16 R)
  101          {
  102   1          int8 scaled_err;
  103   1          // 1. 计算分子：√(a12+a22) - √(b12+b22)
  104   1          float sqrt_a = sqrt((float)L * L + (float)LM * LM);
