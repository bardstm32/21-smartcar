   58          int Median_Average_Filter(int *arr, int times)
   59          {
   60   1          // 初始化最小值、最大值和累加和
   61   1          int min = arr[0], max = arr[0], sum = 0, i = 0;
   62   1      
   63   1          // 遍历数组，更新最小值、最大值，并计算累加和
   64   1          for (i = 0; i < times; i++)
   65   1          {
   66   2              if (arr[i] < min)
   67   2                  min = arr[i]; // 更新最小值
   68   2              if (arr[i] > max)
   69   2                  max = arr[i]; // 更新最大值
   70   2              sum += arr[i];    // 计算累加和
   71   2          }
   72   1      
   73   1          // 返回去掉最大值和最小值后的平均值
   74   1          // 注意：该方法假设times至少为3，否则会导致除以零的错误
   75   1          return (sum - min - max) / (times - 2);
   76   1      }
