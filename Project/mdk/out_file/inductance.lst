   40          /**
   41           * Median_Average_Filter - 计算数组中去掉一个最大值和一个最小值后的平均值
   42           * 该函数接收一个整型数组和一个整数times作为参数，计算数组中去掉一个最大值
   43           * 和一个最小值后的平均值。适用于需要滤除异常值的场景。
   44           * @param arr   整型数组，包含待处理的数据
   45           * @param times 需要处理的数组元素个数
   46           * @return      去掉一个最大值和一个最小值后的数组元素平均值
   47           */
   48          int Median_Average_Filter(int *arr, int times)
   49          {
   50   1          // 初始化最小值、最大值和累加和
   51   1          int min = arr[0], max = arr[0], sum = 0, i = 0;
   52   1          
   53   1          // 遍历数组，更新最小值、最大值，并计算累加和
   54   1          for(i = 0; i < times; i++) {
   55   2              if(arr[i] < min) min = arr[i]; // 更新最小值
C251 COMPILER V5.60.0,  inductance                                                         29/03/26  20:16:09  PAGE 2   

   56   2              if(arr[i] > max) max = arr[i]; // 更新最大值
   57   2              sum += arr[i];                 // 计算累加和
   58   2          }
   59   1          
   60   1          // 返回去掉最大值和最小值后的平均值
   61   1          // 注意：该方法假设times至少为3，否则会导致除以零的错误
   62   1          return (sum - min - max) / (times - 2);
   63   1      }
