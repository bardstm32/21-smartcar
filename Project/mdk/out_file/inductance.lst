   44          /* Аб ADC жЕЯпадЙщвЛЛЏЕН [0,100]ЃЌдННчБЅКЭ */
   45          float ADC_Normalize_0_100(uint16 adc_val, uint16 adc_max, uint16 adc_min)
   46          {
   47   1          float temp;
   48   1      
   49   1          if (adc_val <= adc_min)
   50   1              return 0.0f;
   51   1      
   52   1          if (adc_val >= adc_max)
   53   1              return 100.0f;
   54   1      
   55   1          temp = ((adc_val - adc_min) * 100.0f / (adc_max - adc_min));
   56   1      
   57   1          return temp;
