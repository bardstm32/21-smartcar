   79           * 该函数接收一个ADC值以及最大值和最小值作为参数，将ADC值归一化到0到100之间，
   80           * 并使用range_protect函数确保结果在[1.0, 100.0]范围内。
   81           * @param value     ADC值
   82           * @param max_value 最大值
   83           * @param min_value 最小值
   84           * @return          归一化后的值，范围在[1.0, 100.0]之间
   85           */
   86          float ADC_Normalize_0_100(uint16 adc_val, uint16 adc_max, uint16 adc_min)
   87          {
   88   1          float temp;
   89   1          // 公式：(值 - 最小值) * 100 / (最大值 - 最小值)
   90   1          temp = (adc_val* 100.0f)/ adc_max;
   91   1          // 限幅，防止越界
   92   1          if (temp > 100.0)
   93   1              temp = 100.0;
   94   1          if (temp < 0.0)
   95   1              temp = 0.0;
   96   1          return temp;
   97   1      }
