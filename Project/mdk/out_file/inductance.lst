   85           * @return          归一化后的值，范围在[1.0, 100.0]之间
   86           */
   87          float ADC_Normalize_0_100(uint16 adc_val, uint16 adc_max, uint16 adc_min)
   88          {
   89   1          float temp;
   90   1          // 公式：(值 - 最小值) * 100 / (最大值 - 最小值)
   91   1          temp = (adc_val* 100.0f)/ adc_max;
   92   1          // 限幅，防止越界
   93   1          if (temp > 100.0)
   94   1              temp = 100.0;
   95   1          if (temp < 0.0)
   96   1              temp = 0.0;
   97   1          return temp;
   98   1      }
