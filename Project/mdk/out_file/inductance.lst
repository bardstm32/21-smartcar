   48          /**
   49           * Median_Average_Filter - 计算数组中去掉一个最大值和一个最小值后的平均值
   50           * 该函数接收一个整型数组和一个整数times作为参数，计算数组中去掉一个最大值
   51           * 和一个最小值后的平均值。适用于需要滤除异常值的场景。
   52           * @param arr   整型数组，包含待处理的数据
   53           * @param times 需要处理的数组元素个数
   54           * @return      去掉一个最大值和一个最小值后的数组元素平均值
   55           */
C251 COMPILER V5.60.0,  inductance                                                         17/04/26  16:11:51  PAGE 2   

   56          int Median_Average_Filter(int *arr, int times)
   57          {
   58   1          // 初始化最小值、最大值和累加和
   59   1          int min = arr[0], max = arr[0], sum = 0, i = 0;
   60   1      
   61   1          // 遍历数组，更新最小值、最大值，并计算累加和
   62   1          for (i = 0; i < times; i++)
   63   1          {
   64   2              if (arr[i] < min)
   65   2                  min = arr[i]; // 更新最小值
   66   2              if (arr[i] > max)
   67   2                  max = arr[i]; // 更新最大值
   68   2              sum += arr[i];    // 计算累加和
   69   2          }
   70   1      
   71   1          // 返回去掉最大值和最小值后的平均值
   72   1          // 注意：该方法假设times至少为3，否则会导致除以零的错误
   73   1          return (sum - min - max) / (times - 2);
   74   1      }
