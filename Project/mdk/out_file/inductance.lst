   87          float ADC_Normalize_0_100(uint16 adc_val, uint16 adc_max, uint16 adc_min)
   88          {
   89   1          float temp;
   90   1          
   91   1          // 1. 提前拦截：只要当前值小于等于最小值，直接输出 0，彻底杜绝无符号数相减溢出
   92   1          if (adc_val <= adc_min) 
   93   1              return 0.0f;
   94   1              
   95   1          // 2. 提前拦截：超过最大值直接输出 100（省去了浮点乘除法，提升运行速度）
   96   1          if (adc_val >= adc_max) 
   97   1              return 100.0f;
   98   1      
   99   1          // 3. 在安全范围内，正常计算
  100   1          // 此时 adc_val 必定大于 adc_min，相减绝不会溢出
  101   1          temp = ((adc_val - adc_min) * 100.0f / (adc_max - adc_min));
  102   1      
  103   1          return temp;
