   65          /**
   66           * Adc_Normalize - 将ADC值归一化到指定范围
   67           * 该函数接收一个ADC值以及最大值和最小值作为参数，将ADC值归一化到0到100之间，
   68           * 并使用range_protect函数确保结果在[1.0, 100.0]范围内。
   69           * @param value     ADC值
   70           * @param max_value 最大值
   71           * @param min_value 最小值
   72           * @return          归一化后的值，范围在[1.0, 100.0]之间
   73           */
   74          uint8 ADC_Normalize_0_100(uint16 adc_val, uint16 adc_max, uint16 adc_min)
   75          {
   76   1          uint16 temp;
   77   1          // 公式：(值 - 最小值) * 100 / (最大值 - 最小值)
   78   1          temp = (adc_val - adc_min) * 100 / (adc_max - adc_min);
   79   1          // 限幅，防止越界
   80   1          if(temp > 100) temp = 100;
   81   1          if(temp < 0)   temp = 0;
   82   1          return (uint8)temp;
   83   1      }
