   85          /* Inductance_Count_Err - 差比和计算（按公式修改版）
   86           * 该函数接收四个电感值作为参数，按公式计算电感误差并将其限制在-100到100之间。
   87           * @param L  电感值L（对应公式中a1）
   88           * @param LM 电感值LM（对应公式中a2）
   89           * @param RM 电感值RM（对应公式中b1）
   90           * @param R  电感值R（对应公式中b2）
   91           * @return   电感误差值，范围在[-100, 100]之间
   92           */
   93          int8 Inductance_Count_Err(uint16 L, uint16 LM, uint16 RM, uint16 R) 
   94          {
   95   1          int8 scaled_err;
   96   1          // 1. 计算分子：√(a12+a22) - √(b12+b22)
   97   1          float sqrt_a = sqrt((float)L*L + (float)LM*LM);
   98   1          float sqrt_b = sqrt((float)R*R + (float)RM*RM);
   99   1          float numerator = sqrt_a - sqrt_b;
  100   1          float denominator = sqrt_a + sqrt_b;
  101   1          
  102   1          // 2. 计算并钳制结果
  103   1          if (denominator == 0.0f) {
  104   2              // 避免除零错误，直接返回0或根据需求处理
  105   2              scaled_err = 0;
  106   2          } else {
  107   2              scaled_err = ((int16)numerator / (int16)denominator) * 100;
  108   2          }
  109   1          // 使用range_protect函数确保结果在[-100.0, 100.0]范围内
  110   1          scaled_err = range_protect(scaled_err, -100, 100);
  111   1          // 返回电感误差值
  112   1          return scaled_err;
  113   1      }
