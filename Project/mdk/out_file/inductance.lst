   30          int Median_Average_Filter(uint16 *arr, int times)
   31          {
   32   1          int min = arr[0], max = arr[0], sum = 0, i = 0;
   33   1      
   34   1          for (i = 0; i < times; i++)
   35   1          {
   36   2              if (arr[i] < min) min = arr[i];
   37   2              if (arr[i] > max) max = arr[i];
   38   2              sum += arr[i];
   39   2          }
   40   1      
   41   1          return (sum - min - max) / (times - 2);
   42   1      }
