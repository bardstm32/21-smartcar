  112   2              // 避免除零错误，直接返回0或根据需求处理
  113   2              scaled_err = 0;
  114   2          }
  115   1          else
  116   1          {
  117   2              scaled_err = ((int16)numerator / (int16)denominator) * 100;
  118   2          }
  119   1          // 使用range_protect函数确保结果在[-100.0, 100.0]范围内
