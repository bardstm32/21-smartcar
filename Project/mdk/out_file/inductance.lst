   79          uint8 ADC_Normalize_0_100(uint16 adc_val, uint16 adc_max, uint16 adc_min)
   80          {
   81   1          uint16 temp;
   82   1          // 公式：(值 - 最小值) * 100 / (最大值 - 最小值)
   83   1          temp = (adc_val - adc_min) * 100 / (adc_max - adc_min);
   84   1          // 限幅，防止越界
   85   1          if (temp > 100)
   86   1              temp = 100;
   87   1          if (temp < 0)
   88   1              temp = 0;
   89   1          return (uint8)temp;
