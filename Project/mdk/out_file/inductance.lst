   15          /**
   16           * range_protect - 将值限制在指定的最小值和最大值之间
   17           * 该函数接收一个值以及最小值和最大值作为参数，如果值大于最大值，则返回最大值；
   18           * 如果值小于最小值，则返回最小值；否则返回该值本身。
   19           * @param value     待限制的值
   20           * @param min_value 最小值
   21           * @param max_value 最大值
   22           * @return          限制在[min_value, max_value]之间的值
   23           */
   24          int8 range_protect(int8 value, int8 min_value, int8 max_value)
   25          {
   26   1          return (value > max_value) ? max_value : ((value < min_value) ? min_value : value);
   27   1      }
