   23           * @param max_value 最大值
   24           * @return          限制在[min_value, max_value]之间的值
   25           */
   26          int16 range_protect_int(int16 value, int16 min_value, int16 max_value)
   27          {
   28   1          return (value > max_value) ? max_value : ((value < min_value) ? min_value : value);
   29   1      }
   30          
   31          float range_protect_float(float value, float min_value, float max_value)
   32          {
   33   1          return (value > max_value) ? max_value : ((value < min_value) ? min_value : value);
   34   1      }
