   60          void exti_enable (exti_pin_enum eru_pin)
   61          {
   62   1              switch(eru_pin)
   63   1              {
   64   2                      case INT0_P32: EX0 = 1; break;
   65   2                      
   66   2                      case INT1_P33: EX1 = 1; break;
   67   2                      
   68   2                      case INT2_P36: EX2 = 1; break;
   69   2                      
   70   2                      case INT3_P37: EX3 = 1; break;
   71   2                      
   72   2                      case INT4_P30: EX4 = 1; break;
   73   2                      
   74   2                      default: break;
   75   2              }
   76   1      }
