  111          void exti_init (exti_pin_enum eru_pin, exti_trigger_enum trigger)
  112          {
  113   1              gpio_init( eru_pin & 0XFF, GPIO, 1, GPIO_NO_PULL);
  114   1              
  115   1              // 配置触发方式（仅INT0/INT1可配置）
  116   1              switch(eru_pin)
  117   1          {
  118   2              case INT0_P32: 
  119   2                              IT0 = trigger;
  120   2                              break;
  121   2                      
  122   2              case INT1_P33: 
  123   2                              IT1 = trigger;
  124   2                              break;
  125   2                      
  126   2              case INT2_P36: 
  127   2                               // 仅下降沿触发，无需配置
  128   2                              break;
  129   2                      
  130   2              case INT3_P37: 
  131   2                               // 仅下降沿触发，无需配置
  132   2                              break;
  133   2                      
  134   2              case INT4_P30: 
  135   2                               // 仅下降沿触发，无需配置
  136   2                              break;
  137   2                      
  138   2              default: break;
  139   2          }
  140   1      
  141   1              exti_enable(eru_pin);   // 中断使能
  142   1      }
