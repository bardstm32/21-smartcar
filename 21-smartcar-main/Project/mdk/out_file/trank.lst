   56          float PID_Calc(PID_TypeDef *pid, float target, float measure)
   57          {
   58   1          pid->target = target;
   59   1          pid->measure = measure;
   60   1          
   61   1          // МЦЫуЮѓВю
   62   1          pid->err = pid->target - pid->measure;
   63   1          
   64   1          // БШР§Яю
   65   1          pid->P = pid->Kp * pid->err;  
   66   1              pid->P2 = pid->Kp2 * pid->err*My_abs(pid->err);  
   67   1      
   68   1          // ЮЂЗжЯю
   69   1          pid->D = pid->Kd * (pid->err - pid->last_err);  
   70   1          // змЪфГі+ЯоЗљ
   71   1      //      pid->last_f_speed=pid->err - pid->last_err;
   72   1              
   73   1          pid->out = pid->P + pid->P2+ pid->D;   
   74   1          // ИќаТЮѓВю
   75   1          pid->last_err = pid->err;
   76   1          
   77   1          return pid->out;
   78   1      }
